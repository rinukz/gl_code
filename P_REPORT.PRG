  @ 3,5 SAY STR(SATITEM,8)
  Z1=2
ELSE
  ENDITEM=GLSUB.ITEM
  Z1=1
  @ 3,14 SAY 'To'
  @ 3,17 SAY STR(ENDITEM,8)
  RP_CONF=CK_REPORT()
  IF .NOT.(READKEY()=12.OR.READKEY()=268)
    IF SATITEM>ENDITEM
      Z2=SATITEM
      SATITEM=ENDITEM
      ENDITEM=Z2
    ENDIF
    DEAC POPUP
  ENDIF
ENDIF
RETURN

FUNC CK_BEGIP
PARA Q1
