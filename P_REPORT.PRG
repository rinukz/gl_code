DIME LED(10)
DO WHILE CODE<=ENDAC.AND..NOT.EOF().AND.PF
  ACC=CODE
  ACN=NAME
  WAIT '  Searching... '+ACC WIND NOWAIT
  IF ACC<'4'.AND.&I_PEMBEF<>0
    LED(1)=A_PER(I_PEMNOW,2)
    LED(2)=''
    LED(3)=0
    LED(4)=''
    LED(5)=''
    LED(6)=''
    LED(7)={}
    LED(8)='АКІАЎҝО'
    IF &I_PEMBEF<0
      LED(9)=0
      LED(10)=-&I_PEMBEF
    ELSE
      LED(9)=&I_PEMBEF
      LED(10)=0
    ENDIF
    SELE GLLED
      APPE FROM ARRAY LED
    SELE 2
  ENDIF
  SELE 5
  USE (I_PATH)+'GLSUB' ORDER ITEM ALIA GLSUB
  SELE 4
  USE (I_PATH)+'GLDAT' ORDER ITEM ALIA GLDAT
  SET RELA TO ITEM INTO GLSUB
  SET FILT TO CODE=ACC
  GO TOP
  DO WHILE .NOT.EOF().AND.PF
    LED(1)=GLSUB.DATE
    LED(2)=BOOK
    LED(3)=ITEM
    LED(4)=GLSUB.REFE
    LED(5)=GLSUB.REFE2
    LED(6)=GLSUB.CHEQUE
    LED(7)=GLSUB.CDATE
    LED(8)=ALLTRIM(GLSUB.NOTE)
    IF LEN(LED(8))>48)
      LED(8)=LEFT(GLSUB.NOTE,48)+'..'
    ENDIF     
    LED(9)=DR
    LED(10)=CR
    SELE GLLED
    APPE FROM ARRAY LED
    SELE GLDAT
    SKIP
  ENDDO
  SELE GLLED
  IF PF
    DO PRNAC1
  ENDIF
  ZAP
  SELE GLAC
  SKIP
ENDDO
ENDPRINTJOB
IF SET('PRINT')='ON'
  ??? CHR(18)
ENDIF
DO END_RP
ON ESCA
SET ESCA OFF
SELE 5
USE
SELE 4
USE
SELE 7
USE
