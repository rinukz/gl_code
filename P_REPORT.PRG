PROC PRNVAT
DIME VT(6),ADD(4)
lDelete= SET('DELETE')
SET DELE ON
DO CN_ADD
DO INITPRN
DO SAT_RP
IF SET('PRINT')='ON'
  SET MARGIN TO 3
  ??? CHR(15)
  ??? '{ESC}P'
ENDIF
SET ESCA ON
ON ESCA DO PRNABORT
PRINTJOB
SELE 7
USE (I_PATH)+'GLVAT' ORDER DATE ALIA GLVAT
PRNFLAG=.T.
IF .NOT.VAT_F
  WAIT '  Searching... ' WIND NOWAIT
  ZAP
  SELE 4
  USE (I_PATH)+'GLDAT' ORDER ITEM ALIA GLDAT
  SET RELA TO CODE INTO GLAC
  SELE 5
  USE (I_PATH)+'GLSUB' ORDER ITEM ALIA GLSUB
  cRecc=TRANSFORM(RECC(),'999,999')
  SET RELA TO ITEM INTO GLDAT
  GO TOP
  DO WHILE .NOT.EOF().AND.PRNFLAG
    WAIT '  Search item '+TRANSFORM(ITEM,'999,999')+' OF '+cRecc+'  ' WIND NOWAIT
    VT(1)=DATE
    VT(2)=REFE2
    VT(3)=ALLTRIM(NOTE)
    IF LEN(VT(3))>55
      VT(3)=LEFT(VT(3),55)+'..'
    ENDIF
    SELE GLDAT
    GO TOP
    LOCATE FOR  ITEM=GLSUB.ITEM .AND. CODE=I_TVAT
    IF FOUND()
      VT(5)=IIF(DR<>0,DR,CR)
      VT(6)=IIF(DR<>0,'P','S')
      SUM CR TO VT(4) ALL FOR ITEM=GLSUB.ITEM
      VT(4)=VT(4)-VT(5)
      SELE GLVAT
      APPE FROM ARRAY VT
      SELE GLDAT
    ENDIF
    GO TOP
    SELE GLSUB
    SKIP
  ENDDO
  IF PRNFLAG
    VAT_F=.T.
  ENDIF
  SELE GLDAT
  USE
  SELE GLSUB
  USE
ENDIF
WAIT '  Printing... ' WIND NOWAIT
DO PRNVAT0
ON ESCA
SET ESCA OFF
SET DELETE &lDelete
ENDPRINTJOB
IF SET('PRINT')='ON'
  ??? CHR(18)
  SET MARGIN TO 0
ENDIF
DO END_RP
RETURN

PROC CN_ADD
PRIV I,J,K,AD
AD=I_ADD
FOR K=1 TO 3
  FOR I=25 TO LEN(AD)
    J=ADDRAT(AD,I)
    IF J>0
      ADD(K)=ALLTRIM(LEFT(AD,J-1))
      EXIT
    ENDIF
  ENDFOR
  AD=RIGHT(AD,LEN(AD)-J)
ENDFOR
ADD(4)=AD
RETURN

