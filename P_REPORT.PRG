PROC SELE_SUB
PRIV CNF,Q1,Q2,Q3,Q4,Q5,Q6,Q9,G_ORDER,G_FROM,G_TO,G_FIEL,G_SUB,G_SORT,TYPE8H2,TYPE8H3,TYPE8H4,TYPE8H5
SELE 4
USE (I_PATH)+'GLDAT' ALIA GLDAT
SELE 5
USE (I_PATH)+'GLSUB' ALIA GLSUB
DEFI WIND GETSIN FROM 1,5 TO 22,75
ACTI WIND GETSIN
Q4=1
Q5=2
TYPE8H1='БОАЎОББОАДЭ·'
TYPE8H2=''
TYPE8H3=''
TYPE8H4=''
TYPE8H5=''
G_FROM=''
G_TO=''
G_FIEL=''
G_SUB=''
@ 1,1 GET Q1 FUNC '*C \<Range' DEFA .T. VALID GETQ1() MESS 'ЎПИ·ІЁаДҘўбКҝШГ'
@ 2,5 GET Q2 FUNC '*R Item;Date;Voucher;Reference;Cheque;Cheque-Date' DEFA 1 VALID GETQ2() DISA MESS 'ўбКҝШГөЪаібКҘЎОБЎПИ·ІЁаДҘ'
@ 1,25 SAY 'Sort By' 
@ 2,25 GET Q5 FUNC '*R \<Item;\<Date;\<Voucher;\<Reference;\<Cheque;Che\<que-Date' DEFA 2 VALID GETQ5() MESS 'ўбКҝШГөЪаібКҘЎОБРБЪАҘГПІЭё'
@ 1,50 GET Q8 FUNC '*C \<Normal'   DEFA .T. MESS '   РГЬКЎјЩҝјдіОҝ№ЎіЩ/јЩҝјдЗКҘБОАЎОБіаКИ·ЫаҘИ·бО'
@ 2,50 GET Q6 FUNC '*C \<All Book' DEFA .T. VALID GETQ6() MESS 'РГЬКЎЗҝЧІБОАДЭ·'
@ 18,25 GET CNF FUNC '*RT \<OK;\<Cancel' defa 2
READ CYCLE
IF CNF=1
  RP_CONF=CK_REPORT()
  IF RP_CONF<>2
    WAIT '  Searching... ' WIND NOWAIT
    DO CASE
      CASE Q5=1
        G_ORDER='GLSUB.ITEM'
        TYPE8H3='ГПІЭёөЪа'
      CASE Q5=2
        G_ORDER='DATE'
        TYPE8H3='ДЭ·өЪа'
      CASE Q5=3
        G_ORDER='REFE'
        TYPE8H3='РГўөЪаУёЈЧҝРКЎЗОБ'
      CASE Q5=4
        G_ORDER='REFE2'
        TYPE8H3='РГўөЪаРКЎЗОБ'
      CASE Q5=5
        G_ORDER='CHEQUE'
        TYPE8H3='РГўөЪаРЁЯЈ'
      CASE Q5=6
        G_ORDER='CDATE'
        TYPE8H3='ДЭ·өЪаЗЭаҘҰаОАРЁЯЈ'
    ENDCASE
    TYPE8=Q6
    IF Q6=.F.
      G_CON='BOOK="'+G_SUB+'"'
    ELSE
      G_CON=''
    ENDIF
    TYPE8H1=TRIM(TYPE8H1)+' РБЪАҘіОҝ '+TYPE8H3
    TYPE8H6=''
    IF Q1=.T.
      SELE 7
      USE
      IF Q6=.T.
        SELECT ALL GLSUB.DATE,GLDAT.BOOK,GLSUB.ITEM,GLSUB.REFE,GLSUB.REFE2,GLSUB.CHEQUE,GLSUB.CDATE,GLSUB.NOTE,GLDAT.CODE,GLAC.NAME,GLDAT.DR,GLDAT.CR;
          FROM GLSUB,GLDAT,GLAC;
          INTO DBF (I_PATH)+'GLTEM' ;
          WHERE GLAC.CODE=GLDAT.CODE .AND. GLSUB.ITEM=GLDAT.ITEM;
          ORDER BY &G_ORDER,GLDAT.ITEM
      ELSE
        SELECT ALL GLSUB.DATE,GLDAT.BOOK,GLSUB.ITEM,GLSUB.REFE,GLSUB.REFE2,GLSUB.CHEQUE,GLSUB.CDATE,GLSUB.NOTE,GLDAT.CODE,GLAC.NAME,GLDAT.DR,GLDAT.CR;
          FROM GLSUB,GLDAT,GLAC;
          INTO DBF (I_PATH)+'GLTEM' ;
          WHERE GLAC.CODE=GLDAT.CODE .AND. GLSUB.ITEM=GLDAT.ITEM .AND. &G_CON;
          ORDER BY &G_ORDER,GLDAT.ITEM
      ENDIF
    ELSE
      TYPE8H6='РБЩаҝҰОЎ '+TYPE8H2+' '+ALLTRIM(TYPE8H4)+' ҙЫҘ '+ALLTRIM(TYPE8H5)
      G_SORT='ASC'
      IF G_FROM>G_TO
        Q9=G_TO
        G_TO=G_FROM
        G_FROM=Q9
        G_SORT='DESC'
        TYPE8H6='РБЩаҝҰОЎ '+TYPE8H2+' '+TYPE8H5+' ҙЫҘ '+TYPE8H4
      ELSE
        TYPE8H6='РБЩаҝҰОЎ '+TYPE8H2+' '+TYPE8H4+' ҙЫҘ '+TYPE8H5
        G_SORT='ASC'
      ENDIF
      IF Q6=.T.
        SELECT ALL GLSUB.DATE,GLDAT.BOOK,GLSUB.ITEM,GLSUB.REFE,GLSUB.REFE2,GLSUB.CHEQUE,GLSUB.CDATE,GLSUB.NOTE,GLDAT.CODE,GLAC.NAME,GLDAT.DR,GLDAT.CR;
          FROM GLSUB,GLDAT,GLAC;
          INTO DBF (I_PATH)+'GLTEM' ;
          WHERE GLAC.CODE=GLDAT.CODE .AND. GLSUB.ITEM=GLDAT.ITEM .AND.BETWEEN(&G_FIEL,G_FROM,G_TO) ;
       	  ORDER BY &G_ORDER &G_SORT ,GLDAT.ITEM
      ELSE
        SELECT ALL GLSUB.DATE,GLDAT.BOOK,GLSUB.ITEM,GLSUB.REFE,GLSUB.REFE2,GLSUB.CHEQUE,GLSUB.CDATE,GLSUB.NOTE,GLDAT.CODE,GLAC.NAME,GLDAT.DR,GLDAT.CR;
          FROM GLSUB,GLDAT,GLAC;
          INTO DBF (I_PATH)+'GLTEM' ;
          WHERE GLAC.CODE=GLDAT.CODE .AND. GLSUB.ITEM=GLDAT.ITEM .AND.BETWEEN(&G_FIEL,G_FROM,G_TO) .AND.&G_CON;
          ORDER BY &G_ORDER &G_SORT ,GLDAT.ITEM
      ENDIF
    ENDIF
  ENDIF
  USE
  SELE 5
  USE
  SELE 4
  USE
ENDIF
RELE WIND GETSIN
RELE POPUP POPQ2,POPSUB
RETURN

