PROC P_REPORT
PRIV RP_TYPE,RP_SATP,RP_ENDP,RP_SATB,RP_ENDB,BEGI_BAR
ON KEY LABEL ESC
MPAD='P5'
SHOW MENU MAIN
WAIT '   Wait...  ' WIND NOWAIT
RP_TYPE=1
RP_TO=3
VAT_F=.F.
TO_FILE=(I_PATH)+'GLREPORT.TXT'
RP_COMP=.T.
RP_CONF=1
RP_SATP=''
RP_ENDP=''
RP_ENDPS=''
RP_SATB=''
RP_ENDB=''
RP_ENDBS=''
RP_SATDP={}
RP_ENDDP={}
BEGI_BAR=1
OLD_ENDBAR=0
OLD_SATBAR=0
NEW_ENDBAR=0
NEW_SATBAR=0
SELE 4
USE (I_PATH)+'GLDAT' ALIA GLDAT
SELE 5
USE (I_PATH)+'GLSUB' ALIA GLSUB
SELE 7
SELECT DISTINCT GLSUB.ITEM   AS POP FROM GLSUB INTO DBF (I_PATH)+'POP1' ORDER BY GLSUB.ITEM
SELECT DISTINCT GLSUB.DATE   AS POP FROM GLSUB INTO DBF (I_PATH)+'POP2' ORDER BY GLSUB.DATE
SELECT DISTINCT GLSUB.REFE   AS POP FROM GLSUB INTO DBF (I_PATH)+'POP3' ORDER BY GLSUB.REFE
SELECT DISTINCT GLSUB.REFE2  AS POP FROM GLSUB INTO DBF (I_PATH)+'POP4' ORDER BY GLSUB.REFE2
SELECT DISTINCT GLSUB.CHEQUE AS POP FROM GLSUB INTO DBF (I_PATH)+'POP5' ORDER BY GLSUB.CHEQUE
SELECT DISTINCT GLSUB.CDATE  AS POP FROM GLSUB INTO DBF (I_PATH)+'POP6' ORDER BY GLSUB.CDATE
CLOSE DATABASE
SELE 1
USE (I_PATH)+'GLMAS' ALIA GLMAS
DEFI POPUP SELE_GP FROM 8,33 TO 20,79 IN SCREEN PROM FIEL GLMAS.GP+' '+GLMAS.NAME SCRO
ON SELE POPUP SELE_GP DO SELE_GP
SELE 2
USE (I_PATH)+'GLAC' ORDER CODE ALIA GLAC
DEFI POPUP SELE_AC FROM 8,33 TO 20,79 IN SCREEN PROM FIEL GLAC.CODE+' '+LEFT(GLAC.NAME,34) SCRO
ON SELE POPUP SELE_AC DO SELE_AC
if demoflag
  do ck_demo with 50
endif
SELE 3
USE (I_PATH)+'GLSUBXX' ALIA SUBXX
SELE 6
USE (I_PATH)+'GLPER' ALIA 'GLPER'
GOTO I_PEMNOW
RP_SATD=PSAT
RP_ENDD=PEND
DIME A_PER(I_PEMNOW,5)
COPY TO ARRAY A_PER FOR PNO<=I_PEMNOW
DEFI POPUP PSAT FROM 1,40 TO 2+I_PEMNOW,50 TITLE ' Start '
DEFI POPUP PEND FROM 1,60 TO 2+I_PEMNOW,70 TITLE ' End '
DEFI POPUP PPER FROM 1,40 TO 2+I_PEMNOW,52 TITLE ' Date-Ended '
FOR I=1 TO I_PEMNOW
DEFI BAR I OF PSAT PROM DTOC(A_PER(I,2))
DEFI BAR I OF PPER PROM DTOC(A_PER(I,3))
ENDFOR
ON SELE POPUP PSAT DO RP_SAT
ON SELE POPUP PEND DO RP_END
ON SELE POPUP PPER DO RP_PER
DEFI POPUP RP_TYPE FROM 1,0 TO 20,30 TITLE ' Report Type ' MESS 'Select Report Type'
DEFI BAR  1 OF RP_TYPE PROM ' \<Balance Sheet' MESS 'ҘёІЧГ'
DEFI BAR  2 OF RP_TYPE PROM ' \<Profit and Loss' MESS 'ҘёЎПФБўОІөЧ·'
DEFI BAR  3 OF RP_TYPE PROM ' \<Cost of Goods sold' MESS 'Ҙёіб·өЧ·ЗЩ·ЈбОөЪаўОА'
DEFI BAR  4 OF RP_TYPE PROM ' ' SKIP
DEFI BAR  5 OF RP_TYPE PROM ' \<Worksheet' MESS 'ЎБМІОЖөПЎОБ'
DEFI BAR  6 OF RP_TYPE PROM ' ' SKIP
DEFI BAR  7 OF RP_TYPE PROM ' \<Trial Balance' MESS 'ҘёөІГКҘ'
DEFI BAR  8 OF RP_TYPE PROM ' \<Subsidiary Books' MESS 'ЗҝЧІБОАДЭ·'
DEFI BAR  9 OF RP_TYPE PROM ' \<Ledger' MESS 'ёЭ«ЁЪСАЎ№БМРҫө'
DEFI BAR 10 OF RP_TYPE PROM ' ' SKIP
DEFI BAR 11 OF RP_TYPE PROM ' P\<urchases VAT      ' MESS 'ҫОЖЪ©ЬбК'
DEFI BAR 12 OF RP_TYPE PROM ' S\<ale VAT          ' MESS 'ҫОЖЪўОА'
DEFI BAR 13 OF RP_TYPE PROM ' ' SKIP
DEFI BAR 14 OF RP_TYPE PROM ' Account \<Receivable' MESS 'ёЭ«ЁЪГШЎИ·Ъб'
DEFI BAR 15 OF RP_TYPE PROM ' Account Cl\<osing Balance' MESS 'АКІЈҘРИГЬКўКҘЎГЧаҝёЭ«ЁЪ'
DEFI BAR 16 OF RP_TYPE PROM ' Account \<Group' MESS 'БИЭЗЎГЧаҝёЭ«ЁЪ'
DEFI BAR 17 OF RP_TYPE PROM ' \<Edit Report File' MESS 'СЎбУўСҪбҝБОАҘО·'
DEFI BAR 18 OF RP_TYPE PROM ' Pri\<nt Report File' MESS 'јЩҝјдСҪбҝБОАҘО·'
ON SELE POPUP RP_TYPE DO RP_SELE
WAIT CLEAR
ACTI POPUP RP_TYPE
SELE 1
CLOSE DATABASE
RELE POPUPS
RETURN

PROC RP_PER
PRIV Y
Y=BAR()
RP_ENDDP=A_PER(Y,3)
IF Y=I_PEMNOW.AND..NOT.I_CLOSE
  RP_ENDP='CLOS'
ELSE
  RP_ENDP=A_PER(Y,4)
ENDIF
RP_ENDB=A_PER(Y,5)
IF RP_TYPE=14
  RP_CONF=CK_REPORT()
  DEAC POPUP
ELSE
  DO RP_GP
  IF LASTKEY()<>27
    DEAC POPUP
  ENDIF
ENDIF
RETURN

PROC RP_GP
PRIV Q,Q1
DEFI WIND GP FROM 1,33 TO 7,79
ACTI WIND GP
CLEAR
@ 1,1  GET Q PICT '@*RT Select \<Group;Select \<Account' DEFA 1
READ CYCLE
IF READKEY()=12.OR.READKEY()=268
  RELE WIND GP
  RETURN
ENDIF
IF Q=1
  Q1=1
  ACTI POPUP SELE_GP
ELSE
  Q1=1
  ACTI POPUP SELE_AC
ENDIF
RELE WIND GP
RETURN

PROC SELE_AC
PRIV Q2
IF Q1=1
  SATAC=GLAC.CODE
  @ 3,0 SAY 'Code'
  @ 3,5 SAY SATAC
  Q1=2
ELSE
  ENDAC=GLAC.CODE
  Q1=1
  @ 3,15 SAY 'To'
  @ 3,18 SAY ENDAC
  IF RP_TYPE=15
     @ 4,1 SAY 'Heading ' GET HEADGP FUNC 'S30'
     READ
  ENDIF
  RP_CONF=CK_REPORT()
  IF .NOT.(READKEY()=12.OR.READKEY()=268)
    IF SATAC>ENDAC
      Q2=ENDAC
      ENDAC=SATAC
      SATAC=Q2
    ENDIF
    DEAC POPUP
  ENDIF
ENDIF
RETURN

FUNC TLEN
PARA Q
PRIV Q1,Q2,Q3,Q4
Q1=Q
Q2=LEN(Q1)
Q3=0
FOR Q4=1 TO Q2
  IF ASC(SUBSTR(Q1,Q4,1))<215
    Q3=Q3+1
  ENDIF
ENDFOR
RETURN (Q3)

PROC SELE_GP
PRIV Q2
IF Q1=1
  SATAC=GLMAS.GP  
  @ 3,0 SAY 'Code'
  @ 3,5 SAY SATAC
  Q1=2
ELSE
  ENDAC=GLMAS.GP
  Q1=1
  @ 3,15 SAY 'To'
  @ 3,18 SAY ENDAC
  IF RP_TYPE=15
     @ 4,1 SAY 'Heading ' GET HEADGP FUNC 'S30'
     READ
  ENDIF
  RP_CONF=CK_REPORT()
  IF .NOT.(READKEY()=12.OR.READKEY()=268)
    IF SATAC>ENDAC
      Q2=ENDAC
      ENDAC=SATAC
      SATAC=Q2
    ENDIF
    DEAC POPUP
  ENDIF
ENDIF
RETURN

FUNC CK_REPORT
PRIV R1,R2
R2=1
DEFI WIND CK_REPORT FROM 15,40 TO 23,78
ACTI WIND CK_REPORT
CLEAR
RP_TO=3
IF RP_TYPE<5.OR.RP_TYPE=14.OR.RP_TYPE=15
  @ 1,1  GET RP_COMP  PICT '@*C Co\<mpare      ' MESS 'Р№БЪАёРөЪАё'
ENDIF
@ 3,1  GET RP_TO PICT '@*RT \<Printer;\<File;\<Display' MESS 'БОАҘО·әГККЎөОҘ' VALID CK_FILE()
READ CYCLE
IF READKEY()=12.OR.READKEY()=268.OR.R2<>1
  R1=2
ELSE
  R1=1
ENDIF
RELE WIND CK_REPORT
RETURN(R1)

PROC CK_FILE
IF RP_TO=2  
  KEYB '{UPARROW}+{UPARROW}'
  TO_FILE=PUTFILE('Print to file',TO_FILE,'TXT')
  IF LASTKEY()=27.OR.LEN(TO_FILE)=0
    TO_FILE=I_PATH+'GLREPORT.TXT'
    R2=2
  ELSE
    R2=1
  ENDIF
ELSE
  R2=1
ENDIF
RETURN(.T.)

PROC RPTRAN
PRIV Y1,Y2,Y3,Y4,INOUTCOME,QQ1,QQ2
SELE 7
USE (I_PATH)+'GLRP03' ORDER COMM1 ALIA GLRP
IF NEW_SATBAR<>OLD_SATBAR.OR.NEW_ENDBAR<>OLD_ENDBAR
  WAIT '  Calculating... ' WIND NOWAIT
  DO RPTRANSAC
  OLD_SATBAR=NEW_SATBAR
  OLD_ENDBAR=NEW_ENDBAR
ENDIF
SELE GLRP
SET ORDER TO TAG LINE
SET FILT TO TYPE=RP_TYPE
DO INITPRN
DO SAT_RP
WAIT '  Printing... ' WIND NOWAIT
SET MARGIN TO 4
PRINT JOB
COL1=50
COL2=70
GO TOP
DO WHILE .NOT.EOF() FOR TYPE=RP_TYPE
  IF .NOT.CK_SK()
    DO CASE
      CASE COMM1='HN'
        ?
        ?? I_CN AT 41-INT(TLEN(ALLTRIM(I_CN))/2)
      CASE COMM1='HD'
        QQ1=TRIM(TEXT)
        QQ2=AT(';;',QQ1)
        ?
        IF QQ2=0
          ?? QQ1
          ?? ' '
          ?? RP_ENDDP
        ELSE
          ?? LEFT(QQ1,QQ2-1)
          ?? RP_SATDP
          ?? RIGHT(QQ1,LEN(QQ1)-QQ2-1)
          ?? ' '
          ?? RP_ENDDP
        ENDIF
      CASE COMM1='HY'
        ?
        IF RP_COMP
          ?? YEAR(RP_ENDDP) PICT '9999' AT COL1+11
          ?? YEAR(RP_ENDDP)-1 PICT '9999' AT COL2+11
        ELSE
          ?? YEAR(RP_ENDDP) PICT '9999' AT COL2+11
        ENDIF
      CASE COMM1='H'
        ?
        ?? TRIM(TEXT) AT 0
      CASE COMM1='L1'        
        IF RP_TO<>1
          ?
        ENDIF
        IF RP_COMP
          ?? '__________________' AT COL1
          ?? '__________________' AT COL2
        ELSE
          ?? '__________________' AT COL2
        ENDIF
      CASE COMM1='L2'
        ?        
        IF RP_COMP
          ?? '==================' AT COL1
          ?? '==================' AT COL2
        ELSE
          ?? '==================' AT COL2
        ENDIF
      CASE COMM1='S'.OR.COMM1='M'
        ?
        ?? TRIM(TEXT) AT 0
        DO PF_DAT WITH DATP,DATB
      CASE COMM1='X1'
        ?
        ?? TRIM(TEXT) AT 0
        DO F_X1
      CASE COMM1='X2'
        ?
        ?? TRIM(TEXT) AT 0
        DO F_X2
    ENDCASE
  ENDIF
  SKIP
ENDDO
ENDPRINTJOB
SET MARGIN TO 0
DO END_RP
SET FILT TO
SELE GLRP
USE
SELE 1
RETURN

PROC PF_DAT
PARA Q1,Q2
  IF RP_COMP
    IF Q1>0
      ?? Q1 PICT '999,999,999,999.99' AT COL1
    ELSE
      ?? Q1 FUNC '(' PICT '999,999,999,999.99' AT COL1-1
    ENDIF
    IF Q2>0
      ?? Q2 PICT '999,999,999,999.99' AT COL2
    ELSE
      ?? Q2 FUNC '(' PICT '999,999,999,999.99' AT COL2-1
    ENDIF
  ELSE
    IF Q1>0
      ?? Q1 PICT '999,999,999,999.99' AT COL2
    ELSE
      ?? Q1 FUNC '(' PICT '999,999,999,999.99' AT COL2-1
    ENDIF
  ENDIF
RETURN

PROC F_X1
PRIV Z
Z=RECNO()
SEEK(4500)
IF I_SHAREP=0
  Z1=0
ELSE
  Z1=DATP/I_SHAREP
ENDIF
IF I_SHAREB=0
  Z2=0
ELSE
  Z2=DATB/I_SHAREB
ENDIF
GOTO Z
DO PF_DAT WITH Z1,Z2
RETURN

PROC F_X2
PRIV Z1,Z2
?? ' '
?? I_SHAREP PICT '999,999,999'
IF I_TOGGLE
  ?? ' ИЧб·'
  ?
  ?? 'ҝШГЈаОИЧб·ГМ ' AT 15
  ?? I_VALUEP PICT '999,999.99'
  ?? ' ёОө'
ELSE
  ?? ' units'
  ?
  ?? 'Bath ' AT 15
  ?? I_VALUEP PICT '999,999.99'
  ?? ' per unit'
ENDIF
Z1=I_SHAREP*I_VALUEP
Z2=I_SHAREB*I_VALUEB
DO PF_DAT WITH Z1,Z2
?
IF RP_COMP
  ?? '==================' AT COL1
  ?? '==================' AT COL2
ELSE
  ?? '==================' AT COL2
ENDIF
RETURN

PROC RPTRANSAC
PRIV MAXVAR
CALC MAX(VAR) TO MAXVAR
SET FILT TO COMM1='S'
SCAN  
  INOUTCOME=IIF(CODEP<'4',.F.,.T.)
  IF CODEB=' '
    Y1="CODE='"+TRIM(CODEP)+"'"
  ELSE
    Y1="CODE>='"+TRIM(CODEP)+"'.AND.CODE<='"+TRIM(CODEB)+"'"
  ENDIF
  Y2=POSI
  SELE GLAC
  SET FILT TO &Y1
  IF Y2=1
    SUM &RP_SATP,&RP_SATB TO Y3,Y4
  ELSE
    IF .NOT.INOUTCOME
      SUM &RP_ENDP,&RP_ENDB TO Y3,Y4
    ELSE
      SUM &RP_ENDPS,&RP_ENDBS TO Y3,Y4    
    ENDIF
  ENDIF
  SET FILT TO
  SELE GLRP
  IF SIGN0='+'  
    REPL DATP WITH Y3,DATB WITH Y4
  ELSE
    REPL DATP WITH -Y3,DATB WITH -Y4
  ENDIF
ENDSCAN  &&******************************** END PART1
DIME YI(MAXVAR,2)
SET FILT TO COMM1='M'
FOR I=1 TO MAXVAR
  Y1=TRIM('M'+ALLTRIM(STR(I)))
  YI(I,1)=0
  YI(I,2)=0
  GO TOP
  IF SEEK(Y1)
    Y3=RECNO()
    SET FILT TO VAR=I
    GO TOP
    DO WHILE .NOT.EOF()
      IF SIGN='+'
         YI(I,1)=YI(I,1)+DATP
         YI(I,2)=YI(I,2)+DATB
      ELSE
         YI(I,1)=YI(I,1)-DATP
         YI(I,2)=YI(I,2)-DATB
      ENDIF
      SKIP
    ENDDO
    SET FILT TO COMM1='M'
	GOTO Y3
	DO WHILE COMM1=Y1    
      REPL DATP WITH YI(I,1),DATB WITH YI(I,2)
      SKIP
    ENDDO
  ENDIF
ENDFOR  &&************************************END PART2
RETURN

PROC SAT_RP
@ 24,0 SAY ' '
DO CASE
  CASE RP_TO=1
    DO WHILE .NOT. PRINTSTATUS()
      WAIT "  (!) PLEASE READY THE PRINTER FOR REPORT  " WIND
      IF LASTKEY()=27
        RETURN TO P_REPORT
      ENDIF
    ENDDO
    SET PRINT ON
    *??? '{ESC}C{0}{11}'
    ??? '{ESC}!'+CHR(1)
  CASE RP_TO=2
    IF RP_TYPE<>9
      SET ALTE TO &TO_FILE
    ELSE
      SET ALTE TO &TO_FILE ADDI
    ENDIF
    SET ALTE ON
  CASE RP_TO=3
    IF RP_TYPE<>9
      SET ALTE TO report.tmp
    ELSE
      SET ALTE TO report.tmp ADDI
    ENDIF
    SET ALTE ON
    _PEJECT='NONE'
    DEFI WIND DP_RP FROM 0,0 TO 23,79
    ACTI WIND DP_RP
ENDCASE
DO INITPRN
SET MARGIN TO 0
RETURN

PROC END_RP
IF RP_TYPE=8.OR.RP_TYPE=14.OR.RP_TYPE=15
  EJECT PAGE
ENDIF
DO CASE
  CASE RP_TO=1
    SET PRINT OFF
  CASE RP_TO=2
    SET ALTE OFF
    SET ALTE TO
    CLOSE ALTE
  CASE RP_TO=3
    ? CHR(7)
    SET ALTE OFF
    SET ALTE TO
    CLOSE ALTE
    DO ShowScr
    ERASE report.tmp
    RELE WIND
ENDCASE
ON PAGE
WAIT '  Print Completed  ' WIND NOWAIT
CLEAR
RETURN

PROC DP_WAIT
  WAIT '  Press any key to continue  ' WIND
  _PLINENO=0
  ?
RETURN

PROC INITPRN
_PBPAGE=1
_PFROM=""
_POFFSET=0
_PSPACING=1
_PWAIT=.f.
_WRAP=.f.
_PSCODE="{27}2"
_PAGENO=1
_PLINENO=0
_PEJECT='AFTER'
_PLENGTH=66
RETURN

FUNC CK_SK
PRIV Z
DO CASE
  CASE SK=-1
    Z=.F.
  CASE SK=1
    Z=.T.
  CASE SK=2
    Z=CK_SKL()
  CASE SK=0
    IF SKL>0
      Z=CK_SKL()
    ELSE
      IF RP_COMP
        IF DATP=0.AND.DATB=0
          Z=.T.
        ELSE
          Z=.F.
        ENDIF
      ELSE
        IF DATP=0
          Z=.T.
        ELSE
          Z=.F.
        ENDIF
      ENDIF
    ENDIF
ENDCASE
RETURN(Z)

FUNC CK_SKL
PRIV Z,Z1
IF SKL>0
  Z1=RECNO()
  SEEK(SKL)
  IF RP_COMP
    IF DATP=0.AND.DATB=0
      Z=.T.
    ELSE
      Z=.F.
    ENDIF
  ELSE
    IF DATP=0
      Z=.T.
    ELSE
      Z=.F.
    ENDIF
  ENDIF
  GOTO Z1
ELSE
  Z=.F.
ENDIF
RETURN(Z)

PROC RP_SAT
PRIV Y
Y=BAR()
BAR1=.T.
BEGI_BAR=Y
NEW_SATBAR=Y
RP_SATP=CK_BEGIP(A_PER(Y,4))
RP_SATB=CK_BEGIB(A_PER(Y,5))
RP_SATDP=A_PER(Y,2)
FOR I=1 TO I_PEMNOW
  IF I<BEGI_BAR
    DEFI BAR I OF PEND PROM DTOC(A_PER(I,3)) SKIP
  ELSE
    DEFI BAR I OF PEND PROM DTOC(A_PER(I,3)) 
  ENDIF
ENDFOR
BAR2=.F.
ACTI POPUP PEND
IF BAR2 
  DEAC POPUP
ENDIF
RETURN

PROC RP_END
PRIV Y,Y1,Y2,Y3
Y=BAR()
BAR2=.T.
NEW_ENDBAR=Y
RP_ENDDP=A_PER(Y,3)
Y2=''
Y3=''
IF Y=I_PEMNOW.AND..NOT.I_CLOSE
  RP_ENDP='CLOS'
ELSE
  RP_ENDP=A_PER(Y,4)
ENDIF
RP_ENDB=A_PER(Y,5)
SELE GLPER
IF BEGI_BAR=Y
  RP_ENDPS=RP_ENDP
  RP_ENDBS=RP_ENDB
ELSE
  GOTO BEGI_BAR
  Y2=PFIELD
  Y3=PFIELDB
  SKIP
  DO WHILE PNO<Y.AND..NOT.EOF()
    Y2=Y2+'+'+PFIELD
    Y3=Y3+'+'+PFIELDB
    SKIP
  ENDDO
  Y2=Y2+'+'+RP_ENDP
  Y3=Y3+'+'+RP_ENDB
  RP_ENDPS=Y2
  RP_ENDBS=Y3
ENDIF
RP_CONF=CK_REPORT()
DEAC POPUP
RETURN

PROC RP_SELE
PRIV SATITEM,ENDITEM,SATAC,ENDAC,BAR1,BAR2,TYPE8H1,TYPE8H6,TYPE8,Q8
RP_TYPE=BAR()
RP_CONF=2
SATITEM=0
ENDITEM=0
BAR1=.F.
BAR2=.F.
TYPE8=.T.
TYPE8H1=''
TYPE8H6=''
SATAC=' '
ENDAC=' '
Q8=.T.
HEADGP=SPACE(40)
SET DELE ON
*llllllllllllllllllll
DO CASE
  CASE RP_TYPE = 1
    TO_FILE=(I_PATH)+'BSREPORT.TXT'
  CASE RP_TYPE = 2
    TO_FILE=(I_PATH)+'PLREPORT.TXT'
  CASE RP_TYPE = 3
    TO_FILE=(I_PATH)+'CSREPORT.TXT'
  CASE RP_TYPE = 15
    TO_FILE=(I_PATH)+'CBREPORT.TXT'
  OTHER
    TO_FILE=(I_PATH)+'GLREPORT.TXT'
ENDCASE
DO CASE
  CASE RP_TYPE<5
    ACTI POPUP PSAT BAR I_PEMNOW
    IF RP_CONF<>2
      DO RPTRAN
    ENDIF
  CASE RP_TYPE = 5
    DO PRN_WRKSHEET
  CASE RP_TYPE=7
    IF CK_REPORT()=2
      RETURN
    ENDIF
    SELE GLPER
    GOTO I_PEMNOW
    RP_SATD=PSAT
    RP_ENDD=PEND
    SELE GLAC
    GO TOP
    WAIT '  Printing... ' WIND NOWAIT
    DO STARTPRN WITH 'FRM1'
  CASE RP_TYPE=8
    DO SELE_SUB
    IF LASTKEY()=27.OR.RP_CONF=2
      RETURN
    ENDIF
      DO RP_PRNSUB
  CASE RP_TYPE=9
    DO SELE_ACC
    IF RP_CONF=2.OR.SATAC=' '
      RETURN     
    ENDIF
    DO PRNAC
  CASE RP_TYPE=11.OR.RP_TYPE=12
    IF CK_REPORT()=2
      RETURN
    ENDIF
    DO PRNVAT
  CASE RP_TYPE=14
    ACTI POPUP PPER
    IF RP_CONF=2
      RETURN
    ENDIF
    SATAC='113'
    ENDAC='113'
    HEADGP=LOOKUP(GLMAS.NAME,'113',GLMAS.GP)
    DO PRNGP
  CASE RP_TYPE=15
    ACTI POPUP PPER
    IF RP_CONF=2.OR.SATAC=' '
      RETURN
    ENDIF
    DO PRNGP
  CASE RP_TYPE=16
    IF CK_REPORT()=2
      RETURN
    ENDIF
    DO PRNGR
  CASE RP_TYPE=17
    VIEWFILE = GETFILE('TXT', 'Select Report File:')
    IF LEN(viewfile)>1
       KEYB '{CTRL+F10}'
       MODI COMM (VIEWFILE)
    ENDIF
  CASE RP_TYPE=18
    VIEWFILE = GETFILE('TXT', 'Select Report File:')
    IF LEN(viewfile)>1
      @24,0
      i=SET('HEADING')
      SET HEADING OFF
      DO initprn
      PRINTJOB
      SET PRINT ON
      TYPE (VIEWFILE)
      SET PRINT OFF
      ENDPRINTJOB
      IF i = 'OFF'
        SET HEADING OFF
      ELSE
        SET HEADING ON
      ENDIF
      CLEAR
    ENDIF
ENDCASE
RETURN

PROC PRNGR
SELE GLMAS
GO TOP
DO INITPRN
DO SAT_RP
PRNFLAG=.T.
SET ESCA ON
ON ESCA DO PRNABORT
PRINTJOB
DO PRNGR_H
FIRSTPAGE=.T.
DO WHILE .NOT.EOF().AND.PRNFLAG
  IF _PLINENO=0.AND..NOT.FIRSTPAGE
    DO PRNGR_H
  ENDIF
  FIRSTPAGE=.F.
  IF _PLINENO=I_EJECT
    EJECT PAGE
    DO PRNGR_H
  ENDIF
  DO PRNGR_B
  SKIP
ENDDO
DO PRNGR_E
ENDPRINTJOB
DO END_RP
ON ESCA
SET ESCA OFF
RETURN

PROC PRNGR_H
?
?? I_CN AT 0
?? _PAGENO PICT '99999' AT 75
?
?? 'БИЭЗСГМЁЬаКЎГЧаҝёЭ«ЁЪ' AT 40-7
?
?? REPL('-',80)
RETURN

PROC PRNGR_B
?
?? GP AT 0
?? NAME AT 10
RETURN

PROC PRNGR_E
?
?? REPL('-',80)
EJECT PAGE
RETURN

PROC PRNGP
SELE GLAC
IF .NOT. SEEK(SATAC)
  SET NEAR ON
  SEEK(SATAC)
  SET NEAR OFF
ENDIF
