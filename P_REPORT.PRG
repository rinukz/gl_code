    ?? R_SUM1 PICT '999,999,999,999.99' AT 97
    ?? R_SUM2 PICT '999,999,999,999.99' AT 115
    ?
    ?? REPL('=',36) AT 97
  ENDIF
  IF !Q8
    EJECT PAGE
  ENDIF
ENDDO
?
?? REPL('-',133) AT 0
IF _PLINENO>I_EJECT-3
   EJECT PAGE
   DO PRNSUB_H
ENDIF
?
?? 'DR' AT 20
?? R_SUM5 PICT '9999999' AT 25
?? 'ITEM.  AMOUNT' AT 35
?? R_SUM3 PICT '999,999,999,999.99' AT 50
?
?? 'CR' AT 20
